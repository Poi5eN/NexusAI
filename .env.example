# ============================================================
# NEXUS Server Environment
# ============================================================

# === Core API Keys (fill these in) ===
OPENROUTER_API_KEY=your_openrouter_api_key_here
HF_API_TOKEN=your_huggingface_api_token_here
WEB_SEARCH_KEY=your_tavily_api_key_here

# === Server ===
PORT=3001
NODE_ENV=development

# === Vector DB (Support Agent RAG — local dev) ===
VECTOR_DB_URL=http://localhost:8000

# ============================================================
# Per-Persona Model Overrides
# ALL via OpenRouter — 100% free, no billing required
# ============================================================
# Fast, smart — good default for travel & image prompts
MODEL_TRAVEL=google/gemini-2.0-flash-exp:free

# Best free large model for general chat
MODEL_CHATBOT=meta-llama/llama-3.3-70b-instruct:free

# Fast + cheap for FAQ-style support
MODEL_SUPPORT=mistralai/mistral-7b-instruct:free

# Best free reasoning model for deep research
MODEL_RESEARCH=deepseek/deepseek-r1:free

# Used to refine/enhance image prompts before sending to HF
MODEL_IMAGE_PROMPT=meta-llama/llama-3.3-70b-instruct:free

# ============================================================
# Hugging Face Image Models (all free inference API)
# ============================================================
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# Alternatives (uncomment to switch):
# HF_IMAGE_MODEL=stabilityai/sdxl-turbo
# HF_IMAGE_MODEL=stabilityai/stable-diffusion-3.5-large-turbo
